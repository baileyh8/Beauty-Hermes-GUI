{
  "name": "beauty-hermes-gui",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight desktop GUI for Hermes Agent.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
